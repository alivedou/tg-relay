# 必填
TG_BOT_TOKEN=你的_bot_token
TG_OWNER_ID=你的_telegram_user_id

# 可选 - Web 健康检查端口（默认 8080）
TG_PORT=8080

# 可选 - Webhook 模式（填写后自动走 Webhook，否则走 Polling）
# TG_WEBHOOK_URL=https://your-app.example.com

# 可选 - 日志级别 DEBUG/INFO/WARNING/ERROR（默认 INFO）
# TG_LOG_LEVEL=INFO

# 可选 - 自定义欢迎语
# TG_WELCOME_OWNER=👋 欢迎回来，主人！
# TG_WELCOME_STRANGER=👋 你好，你的消息会被匿名转发。

# 可选 - 联系方式（/about 中展示）
# TG_OWNER_CONTACT=Email: me@example.com

# 可选 - 速率限制（0=关闭）
# TG_RATE_LIMIT=5
# TG_RATE_WINDOW=10

# 可选 - 消息模板（支持 {name} {username} {id} {queue} {total}）
# TG_MSG_HEADER=📩 {name} (@{username})\nID: {id}
# TG_MSG_FOOTER=—— 队列 #{queue}/{total} ——

# 可选 - 管理面板 Token（/admin?token=xxx）
# TG_ADMIN_TOKEN=mysecret

# 可选 - 数据存储目录（默认脚本同目录，Docker 自动设为 /app/data）
# TG_DATA_DIR=./data
